APP_ENV=production

DATABASE_URL=postgresql://user:password@host:5432/timesheet_production
SECRET_KEY=replace-with-a-strong-random-secret

BACKEND_CORS_ORIGINS=["https://timekeepinghub.com","https://timesheet.fourhubtech.com"]

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Fourhub Timesheet
SMTP_FROM_EMAIL=your-gmail@gmail.com
