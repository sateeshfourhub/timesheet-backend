APP_ENV=preview

DATABASE_URL=postgresql://user:password@host:5432/timesheet_preview
SECRET_KEY=replace-with-a-strong-random-secret

BACKEND_CORS_ORIGINS=["https://preview.timekeepinghub.com"]

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Fourhub Timesheet (Preview)
SMTP_FROM_EMAIL=your-gmail@gmail.com
